# Copiá este archivo a ".env" en la misma carpeta (ver README: "Configuración del archivo .env").
# Formato: NOMBRE=valor sin espacios alrededor del "=".

# --- Claves (al menos una) ---
# Groq (tier gratuito, recomendado para desarrollo): https://console.groq.com/keys
GROQ_API_KEY=

# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# --- Opcional: forzar proveedor y modelo ---
# Valores: groq | openai. Si está vacío, se infiere (p. ej. si solo hay GROQ_API_KEY, se usa groq).
LLM_PROVIDER=groq

# Modelo según la API del proveedor (ej. Groq: llama-3.3-70b-versatile; OpenAI: gpt-4o-mini).
# Dejá vacío después del "=" para usar el predeterminado del código.
LLM_MODEL=llama-3.3-70b-versatile
